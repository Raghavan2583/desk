# DESK — Environment variables template
# Copy to .env and fill real values. NEVER commit .env.

# GitHub API — token array. MVP uses index 0 only.
GITHUB_TOKENS=["your_github_pat_here"]

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_DATASET_RAW=desk_raw
GCP_DATASET_DEV=desk_dev
GCP_DATASET_PROD=desk_prod

# Local auth only — point to your downloaded service account key.
# In GitHub Actions this is handled by the GCP auth step, not this var.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# dbt — point to the profiles.yml committed in this repo
DBT_PROFILES_DIR=./dbt

# Pipeline config
PYPI_TOP_N=1000
RISK_SCORE_VERSION=1
REFRESH_INTERVAL_HOURS=24
